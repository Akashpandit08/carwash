{
  "expo": {
    "name": "WheelWash",
    "slug": "wheelwash",
    "scheme": "wheelwash",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications",
      "expo-web-browser"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wheelwash.customer",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "WheelWash uses your location to find your service address for doorstep car wash bookings."
      }
    },
    "android": {
      "package": "com.wheelwash.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0877F2"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "9dcf48e1-e287-4dda-98fb-5c45aabb6c0c"
      },
      "router": {}
    },
    "owner": "akashpandit08"
  }
}
