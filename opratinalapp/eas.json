{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://wheelwash.gutargu.app/api",
        "EXPO_PUBLIC_STORAGE_URL": "https://wheelwash.gutargu.app/storage"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://wheelwash.gutargu.app/api",
        "EXPO_PUBLIC_STORAGE_URL": "https://wheelwash.gutargu.app/storage"
      }
    }
  }
}
