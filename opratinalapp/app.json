{
  "expo": {
    "name": "WashMate Operations",
    "slug": "WashMateOperations",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-foreground.png",
          "color": "#2196F3",
          "defaultChannel": "default"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "$GOOGLE_MAPS_IOS_API_KEY"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.akashpandit08.WashMateOperations",
      "permissions": [
        "POST_NOTIFICATIONS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "$GOOGLE_MAPS_ANDROID_API_KEY"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "googleMapsAndroidApiKey": "$GOOGLE_MAPS_ANDROID_API_KEY",
      "googleMapsIosApiKey": "$GOOGLE_MAPS_IOS_API_KEY",
      "eas": {
        "projectId": "ae4d3bfe-9c71-46db-b043-991e77d88f55"
      }
    }
  }
}
